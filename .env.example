DATABASE_URI=postgresql://localhost:5432/your_database_name
PAYLOAD_SECRET=your-secret-key-here-change-in-prod
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Executive dashboard (HTTP Basic Auth for /dashboard)
# -------------------------------------------------------------------------
# DEV-ONLY EXAMPLES — MUST be changed in every non-dev environment.
# In production (NODE_ENV=production), DASHBOARD_USERNAME and
# DASHBOARD_PASSWORD are REQUIRED. If either is unset, the /dashboard
# middleware returns 500 and refuses all requests — there is no fallback.
# Generate a strong password (e.g. `openssl rand -base64 32`) and set it in
# your deployment platform's secret store (Vercel Project Settings, etc.).
# Do NOT commit real credentials to this file.
# -------------------------------------------------------------------------
DASHBOARD_USERNAME=lackey
DASHBOARD_PASSWORD=change-me-in-every-environment

# Foursquare Places API (nearby urgent care search)
# -------------------------------------------------------------------------
# When a patient's triage result is "Urgent", we look up real-world urgent
# care facilities within 10 miles of their location via Foursquare Places.
# Get a free API key at https://foursquare.com/developers/.
# If unset, the feature gracefully falls back to the seeded urgent care list.
# -------------------------------------------------------------------------
FOURSQUARE_API_KEY=
