# =============================================================================
# Lackey Care Navigation — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values before running the app.
# See docs/environment-setup.md for detailed setup instructions.
#
# IMPORTANT: Never commit .env to version control. Only .env.example is tracked.
# =============================================================================

# Node environment (controls CSP strictness, middleware fail-fast, sample-sessions guard)
# Values: "development" (default for npm run dev) | "production" (for Docker / Vercel)
# NODE_ENV is set automatically by Next.js — you do NOT need to set it manually
# unless running custom scripts.
# NODE_ENV=production

# PostgreSQL connection string.
# For Docker Compose: postgresql://lackey:<DB_PASSWORD>@db:5432/lackey_care_navigation
# For local dev: postgresql://postgres:postgres@127.0.0.1:5432/lackey_care_navigation
DATABASE_URI=postgresql://localhost:5432/your_database_name

# Payload CMS secret key — used to sign JWTs for admin authentication.
# MUST be a strong random string in production (e.g., `openssl rand -base64 32`).
# An empty or weak secret means anyone can forge admin sessions.
PAYLOAD_SECRET=your-secret-key-here-change-in-prod

# Public-facing URL of the application (used for canonical URLs, OG images).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Executive dashboard (HTTP Basic Auth for /dashboard)
# -------------------------------------------------------------------------
# DEV-ONLY EXAMPLES — MUST be changed in every non-dev environment.
# In production (NODE_ENV=production), DASHBOARD_USERNAME and
# DASHBOARD_PASSWORD are REQUIRED. If either is unset, the /dashboard
# middleware returns 500 and refuses all requests — there is no fallback.
# Generate a strong password (e.g. `openssl rand -base64 32`) and set it in
# your deployment platform's secret store (Vercel Project Settings, etc.).
# Do NOT commit real credentials to this file.
# -------------------------------------------------------------------------
DASHBOARD_USERNAME=lackey
DASHBOARD_PASSWORD=change-me-in-every-environment

# Foursquare Places API (nearby urgent care search)
# -------------------------------------------------------------------------
# When a patient's triage result is "Urgent", we look up real-world urgent
# care facilities within 10 miles of their location via Foursquare Places.
# Get a free API key at https://foursquare.com/developers/.
# If unset, the feature gracefully falls back to the seeded urgent care list.
# -------------------------------------------------------------------------
FOURSQUARE_API_KEY=
